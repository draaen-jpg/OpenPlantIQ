{
  "version": 2,
  "buildCommand": "cd client && npm install --include=dev && npx vite build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
